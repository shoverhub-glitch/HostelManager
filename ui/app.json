    },
    "extra": {
      "router": {},
      "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "286636123791-d19psn7pd71nc3mb1mco6a4tduaf2f8q.apps.googleusercontent.com",
      "eas": {
        "projectId": "003a4900-798f-433b-806f-248f67236d1a"
      }
    },
    "android": {
      "package": "com.shoverhub.hostelmanager",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/hm-logo-v2.jpg",
        "backgroundColor": "#FFFFFF"
      },
      "blockedPermissions": [
        "android.permission.READ_PHONE_STATE"
      ]
    }
