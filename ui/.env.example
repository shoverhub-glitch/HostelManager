# ============================================================================
# PROPERTY MANAGEMENT SYSTEM (React Native) - ENVIRONMENT CONFIGURATION
# ============================================================================
# This file contains all environment variables for the frontend/mobile app.
# Copy this file to .env.local and update with your actual values.
# IMPORTANT: Public variables must be prefixed with EXPO_PUBLIC_
# ============================================================================


# ============================================================================
# API CONFIGURATION
# ============================================================================
# Backend API URL for all API calls

# Backend API Base URL (Required)
# Format: http://localhost:8000/api/v1 (development) or https://api.yourdomain.com/api/v1 (production)
EXPO_PUBLIC_API_URL=https://hostel.shoverhub.com/api/v1


# ============================================================================
# GOOGLE OAUTH CONFIGURATION
# ============================================================================
# Google OAuth credentials for social login (Optional)
# Get OAuth credentials from: https://console.cloud.google.com/apis/credentials

# Google OAuth Client ID - Expo/Web (Optional, required for web app login)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# Google OAuth Client ID - Android (Optional, required for Android app login)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com

# Google OAuth Client ID - iOS (Optional, required for iOS app login)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id.apps.googleusercontent.com

# Google Expo Client ID (Optional, alternative for Expo Go)
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=your_google_expo_client_id.apps.googleusercontent.com


# ============================================================================
# APP DISTRIBUTION
# ============================================================================
# Store links for app distribution

# Google Play Store URL (Optional)
# URL where users can download the Android app from Play Store
EXPO_PUBLIC_PLAYSTORE_URL=https://play.google.com/store/apps/details?id=com.yourcompany.propertymanagement
