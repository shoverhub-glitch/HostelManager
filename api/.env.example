# ENV: Runtime environment. Use production in live deployments.
ENV=production

# APP_URL: Public backend base URL used for callback links.
APP_URL=https://yourdomain.com

# MONGO_URL: MongoDB connection URI.
MONGO_URL=mongodb://admin:password@your-mongo-server:27017/?authSource=admin

# MONGO_DB_NAME: Database name used by the application.
MONGO_DB_NAME=hostel_manager

# JWT_SECRET: Secret key for signing JWT tokens (keep long and private).
JWT_SECRET=your-super-secret-key-32-chars-minimum-here

# FROM_EMAIL: Sender address used for system emails.
FROM_EMAIL=noreply@yourdomain.com

# ZEPTO_MAIL_API_KEY: API key for Zepto Mail email delivery.
ZEPTO_MAIL_API_KEY=your-zoho-zepto-mail-api-key

# RAZORPAY_KEY_ID: Razorpay public key id.
RAZORPAY_KEY_ID=your-razorpay-key-id

# RAZORPAY_KEY_SECRET: Razorpay secret key.
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# RAZORPAY_WEBHOOK_SECRET: Secret used to verify Razorpay webhook signatures.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ALLOWED_ORIGINS: Comma-separated frontend origins allowed by CORS.
ALLOWED_ORIGINS=https://yourdomain.com

# BACKUP_RETENTION_DAYS: Number of days to retain backups.
BACKUP_RETENTION_DAYS=7

# ADMIN_ACCESS_EMAILS: Comma-separated admin emails allowed for admin routes.
ADMIN_ACCESS_EMAILS=admin@example.com

# DEMO_OTP: Fixed OTP used only when ENV is not production.
DEMO_OTP=130499
