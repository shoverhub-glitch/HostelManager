# ============================================================================
# PROPERTY MANAGEMENT SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================================
# This file contains all environment variables required for the backend API.
# Copy this file to .env and update with your actual values.
# IMPORTANT: Never commit .env to version control - use .env.example instead.
# ============================================================================


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# MongoDB connection string and database name

# Default for local/server Docker Compose deployment
# Backend connects to the mongodb service defined in docker-compose.yml
MONGO_URL=mongodb://mongodb:27017/hostelmanager

# If you prefer MongoDB Atlas instead of the local container, use:
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/hostelmanager?retryWrites=true&w=majority

# MongoDB database name (Optional, default: "project")
MONGO_DB_NAME=hostelmanager


# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Secrets and token expiration settings for JWT authentication

# JWT secret key (Required)
# IMPORTANT: Must be at least 32 characters long for security
# Generate with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_here

# JWT algorithm (Optional, default: "HS256")
JWT_ALGORITHM=HS256

# Access token expiration time in minutes (Optional, default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expiration time in minutes (Optional, default: 10080 = 7 days)
REFRESH_TOKEN_EXPIRE_MINUTES=10080


# ============================================================================
# CORS & SECURITY
# ============================================================================
# Cross-Origin Resource Sharing and security settings

# Allowed origins for CORS (Required)
# Comma-separated list of domains allowed to access the API
# Replace YOUR_SERVER_PUBLIC_IP with the EC2 public IP or your domain before deployment
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://YOUR_SERVER_PUBLIC_IP

# Allow credentials (Optional, default: false)
# Set to true if frontend sends cookies or auth headers
ALLOW_CREDENTIALS=false

# Enforce HTTPS (Optional, default: false)
# Set to true in production to redirect all HTTP to HTTPS
ENFORCE_HTTPS=false


# ============================================================================
# PAYMENT PROCESSING - RAZORPAY
# ============================================================================
# Razorpay integration for subscription payments

# Razorpay Key ID (Required for payment processing)
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id

# Razorpay Key Secret (Required for payment processing)
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Razorpay Webhook Secret (Recommended for webhook verification)
# Generate in: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret


# ============================================================================
# EMAIL SERVICE - ZOHO ZEPTO MAIL
# ============================================================================
# Email delivery for OTP, password resets, and notifications

# Zoho Zepto Mail API key (Optional, required if email features are enabled)
# Get from: https://www.zoho.com/zeptomail/
ZEPTO_MAIL_API_KEY=your_zepto_mail_api_key

# From email address (Optional, required if email features are enabled)
# Should be a verified sender email in your Zoho account
FROM_EMAIL=noreply@yourdomain.com


# ============================================================================
# OAUTH INTEGRATION
# ============================================================================
# Third-party authentication providers

# Google OAuth Client IDs (Optional)
# Comma-separated list of allowed Google Client IDs for authentication
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_IDS=your_google_client_id_1,your_google_client_id_2


# ============================================================================
# ENVIRONMENT & RUNTIME
# ============================================================================
# Application environment and runtime settings

# Environment name (Optional, default: "production")
# Values: development, staging, production
ENV=production

# Public API paths (Optional)
# Comma-separated list of paths that don't require authentication
# If not set, uses default paths (health, auth, etc.)
PUBLIC_PATHS=/api/v1/health,/api/v1/auth/login,/api/v1/auth/register


# ============================================================================
# SUBSCRIPTION PLANS
# ============================================================================
# Default subscription plans (free, pro, premium) are automatically created
# when the application starts. No configuration needed in .env file.
#
# Plans are managed via the database and can be customized through the
# PlanService in api/app/services/plan_service.py