{
  "expo": {
    "name": "Hostel Manager",
    "slug": "hostel-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "scheme": "hostelmanager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lohilit101.hostelmanager"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2c359b8-1d34-4e1d-9aaf-be71065ae390"
      },
      "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "286636123791-d19psn7pd71nc3mb1mco6a4tduaf2f8q.apps.googleusercontent.com"
    },
    "android": {
      "package": "com.shoverhub.hostelmanager",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
        ,"blockedPermissions": [
          "android.permission.READ_PHONE_STATE"
        ]
    }
  }
}
